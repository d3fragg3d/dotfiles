[global]
monitor = 0
follow = mouse
width = 360
height = 300
origin = top-right
offset = 48x48
scale = 0
notification_limit = 6

progress_bar = true
progress_bar_height = 8
progress_bar_frame_width = 0

padding = 14
horizontal_padding = 14
text_icon_padding = 10
frame_width = 2
corner_radius = 12
gap_size = 8
separator_height = 0

font = JetBrainsMono Nerd Font 10
line_height = 2
markup = full

format = <b>%s</b>\n%b
alignment = left
vertical_alignment = center

show_age_threshold = 60
word_wrap = yes
ellipsize = middle
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false

idle_threshold = 120
sort = yes

transparency = 0
startup_notification = false

[urgency_low]
timeout = 4
background = "#1a1512"
foreground = "#e8d5bf"
frame_color = "#3d3228"

[urgency_normal]
timeout = 6
background = "#1a1512"
foreground = "#e8d5bf"
frame_color = "#c4956a"

[urgency_critical]
timeout = 0
background = "#1a1512"
foreground = "#c46a6a"
frame_color = "#c46a6a"
